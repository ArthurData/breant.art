---
const locales = [
  { value: 'en', label: 'EN' },
  { value: 'fr', label: 'FR' },
] as const;
---

<div class="lang-switcher" role="group" aria-label="Language switcher">
  {locales.map(({ value, label }) => (
    <button
      class="lang-btn"
      data-lang={value}
      aria-pressed={value === 'en' ? 'true' : 'false'}
    >
      {label}
    </button>
  ))}
</div>
